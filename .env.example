# Facebook verification (required for follow-to-unlock)
NEXT_PUBLIC_FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
NEXT_PUBLIC_FACEBOOK_PAGE_ID=
NEXT_PUBLIC_FACEBOOK_PAGE_URL=https://www.facebook.com/mitchelturner

# SQLite database (posts & bonus content)
# Defaults to file:./dev.db during build if unset or invalid
DATABASE_URL="file:./dev.db"

# Assembly-Scrape blog_posts source (PostgreSQL on Railway or local SQLite)
# Leave unset to use seeded posts only. Do NOT copy the example URL below — it will be ignored.
# Example (Postgres): postgresql://USER:PASSWORD@YOUR-RAILWAY-HOST:5432/railway
# Example (SQLite): sqlite:///./data/meeting_minutes.db
# ASSEMBLY_DATABASE_URL=

# Admin dashboard (/admin)
ADMIN_PASSWORD=
# Optional: separate signing secret (defaults to ADMIN_PASSWORD)
# ADMIN_SECRET=
